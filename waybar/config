[
  {
    "output": "DP-1",
    "position": "left",
    "layer": "top",
    "width": 20,
    "modules-left": [
      "hyprland/language",
      "clock#day",
      "clock#date"
    ],
    "modules-center": [
      "clock#main",
      "hyprland/workspaces"
    ],
    "modules-right": [
      "network",
      "temperature",
      "battery",
      "cpu",
      "memory",
      "tray",
      "wireplumber"
    ],
    "battery": {
      "format": "{capacity}\n{icon}",
      "format-icons": [
        "ΎΚΕ",
        "ΎΚΔ",
        "ΎΚΓ",
        "ΎΚΒ",
        "ΎΚΑ"
      ],
      "states": {
        "critical": 15,
        "low": 40,
        "normal": 60
      }
    },
    "clock#day": {
      "format": "{:%a}",
      "tooltip": false
    },
    "clock#main": {
      "format": "{:%H\n---\n%M}"
    },
    "clock#date": {
      "format": "{:%m\n ~\n%d}",
      "tooltip": false
    },
    "cpu": {
      "interval": 5,
      "format": "{usage}%\r ΎΜδ",
      "states": {
        "normal": 15,
        "warning": 50,
        "critical": 90
      }
    },
    "memory": {
      "interval": 30,
      "format": "{percentage}%\r ΎΔΚ",
      "states": {
        "normal": 50,
        "warning": 70,
        "critical": 90
      }
    },
    "temperature": {
      "format": "{temperatureC}\r┬░CΎΜΚ",
      "critical-threshold": 80
    },
    "hyprland/language": {
      "format-en": "us",
      "format-ru": "ru"
    },
    "network": {
      "interface": "wlp3s0",
      "format": "{ifname}",
      "format-wifi": "ΎΘτ",
