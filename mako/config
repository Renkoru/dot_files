# Dimensions & position
width=350
height=150
margin=10
padding=15
border-size=2
border-radius=12

# Colors (RRGGBBAA format)
background-color=#1e1e2eee
text-color=#cdd6f4ff
border-color=#89b4faff
progress-color=over #313244ff

# Typography
font=JetBrainsMono Nerd Font 11

# Behavior
default-timeout=5000
ignore-timeout=0
max-visible=5

# Position (top-right, top-center, bottom-right, etc.)
anchor=top-right

# Special style for CRITICAL notifications
[urgency=critical]
background-color=#5A1E1EFF
text-color=#FFFFFFFF
border-color=#CC0000FF
border-size=3
default-timeout=0
